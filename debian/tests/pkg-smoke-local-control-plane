#!/bin/sh
set -eu

. /etc/default/dasall-daemon
: "${DASALL_DAEMON_PROFILE_ID:?missing DASALL_DAEMON_PROFILE_ID}"

CONFIG_SMOKE_DIR=$(mktemp -d /tmp/dasall-cli-config-smoke.XXXXXX)
IMPORT_FILE="${CONFIG_SMOKE_DIR}/deepseek.key"
DESIRED_FILE="${CONFIG_SMOKE_DIR}/desired.yaml"
SHOW_BEFORE_JSON="${CONFIG_SMOKE_DIR}/show-before.json"
VALIDATE_JSON="${CONFIG_SMOKE_DIR}/validate.json"
PLAN_JSON="${CONFIG_SMOKE_DIR}/plan.json"
APPLY_JSON="${CONFIG_SMOKE_DIR}/apply.json"
SHOW_AFTER_JSON="${CONFIG_SMOKE_DIR}/show-after.json"
LLM_SECRET_PATH=/var/lib/dasall/secrets/llm/providers/deepseek-prod.secret
MEMORY_DB_PATH=/var/lib/dasall/memory/memory.db
SQLITE_VSS_DIR=/usr/lib/dasall/sqlite-vss
VECTOR0_PATH="${SQLITE_VSS_DIR}/vector0.so"
VSS0_PATH="${SQLITE_VSS_DIR}/vss0.so"
VECTOR_ASSET_BACKUP_DIR="${CONFIG_SMOKE_DIR}/sqlite-vss-backup"

assert_json_contains() {
  json_payload=$1
  expected=$2
  label=$3

  printf '%s\n' "${json_payload}" | grep -Fq "${expected}" || {
    printf '%s: expected JSON fragment not found: %s\n' "${label}" "${expected}" >&2
    exit 1
  }
}

assert_positive_integer() {
  value=$1
  label=$2

  case "${value}" in
    ''|*[!0-9]*)
      printf '%s: expected a non-negative integer, got %s\n' "${label}" "${value}" >&2
      exit 1
      ;;
  esac

  [ "${value}" -ge 1 ] || {
    printf '%s: expected at least one row, got %s\n' "${label}" "${value}" >&2
    exit 1
  }
}

query_sqlite_scalar() {
  db_path=$1
  sql_query=$2

  python3 - "${db_path}" "${sql_query}" <<'PY'
import sqlite3
import sys

db_path = sys.argv[1]
sql_query = sys.argv[2]
with sqlite3.connect(db_path) as connection:
    row = connection.execute(sql_query).fetchone()
    if row is None:
        sys.exit(2)
    print(row[0])
PY
}

cleanup() {
  systemctl disable --now dasall-daemon.service >/dev/null 2>&1 || true
  rm -rf "${CONFIG_SMOKE_DIR}"
}

wait_for_daemon_ready() {
  attempt=0
  while [ "${attempt}" -lt 30 ]; do
    if systemctl is-enabled --quiet dasall-daemon.service >/dev/null 2>&1 &&
       systemctl is-active --quiet dasall-daemon.service >/dev/null 2>&1 &&
       [ -S /run/dasall/daemon.sock ] &&
       [ "$(stat -c '%U:%G' /run/dasall/daemon.sock 2>/dev/null)" = "dasall:dasall" ] &&
       [ "$(stat -c '%a' /run/dasall/daemon.sock 2>/dev/null)" = "600" ] &&
       dasall ping --json >/dev/null 2>&1 &&
       dasall readiness --json >/dev/null 2>&1; then
      return 0
    fi
    attempt=$((attempt + 1))
    sleep 1
  done

  systemctl status --no-pager dasall-daemon.service >&2 || true
  return 1
}

trap cleanup EXIT

SECRET_ALREADY_CONFIGURED=0
if [ -f "${LLM_SECRET_PATH}" ]; then
  SECRET_ALREADY_CONFIGURED=1
else
  : "${DASALL_DEEPSEEK_API_KEY_FILE:?missing DASALL_DEEPSEEK_API_KEY_FILE or ${LLM_SECRET_PATH}}"
  cp "${DASALL_DEEPSEEK_API_KEY_FILE}" "${IMPORT_FILE}"
  chmod 600 "${IMPORT_FILE}"
fi

cat <<EOF > "${DESIRED_FILE}"
schema_version: dasall.config.apply.v1
profile_id: ${DASALL_DAEMON_PROFILE_ID}
daemon:
  socket_path: /run/dasall/daemon.sock
  log_format: text
  diag_enabled: true
  override_enabled: false
  watchdog_enabled: false
service:
  start_now: true
  enable_on_boot: true
operator_access:
  add_users: []
EOF

if [ "${SECRET_ALREADY_CONFIGURED}" -eq 0 ]; then
cat <<EOF >> "${DESIRED_FILE}"
secrets:
  refs:
    - ref: secret://llm/providers/deepseek-prod
      source: file:${IMPORT_FILE}
      auth_profile_name: primary
EOF
fi
chmod 600 "${DESIRED_FILE}"

/usr/sbin/dasall-daemon \
  --validate-only \
  --profile-id="${DASALL_DAEMON_PROFILE_ID}" \
  --config-file /etc/dasall/daemon.json

dasall config show --json > "${SHOW_BEFORE_JSON}"
grep -Fq '"schema_version":"dasall.config.summary.v1"' "${SHOW_BEFORE_JSON}"

dasall config validate --json > "${VALIDATE_JSON}"
grep -Fq '"schema_version":"dasall.config.validate.v1"' "${VALIDATE_JSON}"

dasall config plan --from-file "${DESIRED_FILE}" --json > "${PLAN_JSON}"
grep -Fq '"schema_version":"dasall.config.plan.v1"' "${PLAN_JSON}"
if [ "${SECRET_ALREADY_CONFIGURED}" -eq 0 ]; then
  grep -Fq '"ref":"secret://llm/providers/deepseek-prod"' "${PLAN_JSON}"
fi
grep -Fq '"service_start_requested":true' "${PLAN_JSON}"

dasall config apply --from-file "${DESIRED_FILE}" --no-input --json > "${APPLY_JSON}"
grep -Fq '"outcome":"applied"' "${APPLY_JSON}"
if [ "${SECRET_ALREADY_CONFIGURED}" -eq 0 ]; then
  grep -Fq '"written_secret_refs":["secret://llm/providers/deepseek-prod"]' "${APPLY_JSON}"
fi

grep -Fq '"log_format": "text"' /etc/dasall/daemon.json
grep -Fq '"diag_enabled": true' /etc/dasall/daemon.json
test -f "${LLM_SECRET_PATH}"
chgrp dasall /var/lib/dasall/secrets /var/lib/dasall/secrets/llm /var/lib/dasall/secrets/llm/providers "${LLM_SECRET_PATH}"
chmod 750 /var/lib/dasall/secrets /var/lib/dasall/secrets/llm /var/lib/dasall/secrets/llm/providers
chmod 640 "${LLM_SECRET_PATH}"

wait_for_daemon_ready

dasall config show --json > "${SHOW_AFTER_JSON}"
grep -Fq '"schema_version":"dasall.config.summary.v1"' "${SHOW_AFTER_JSON}"

systemctl is-active --quiet dasall-daemon.service
test -S /run/dasall/daemon.sock
test "$(stat -c '%U:%G' /run/dasall/daemon.sock)" = "dasall:dasall"
test "$(stat -c '%a' /run/dasall/daemon.sock)" = "600"

dasall ping --json >/dev/null
dasall readiness --json >/dev/null
RUN_JSON=$(dasall run '{"prompt":"package smoke"}' --json --timeout-ms 120000)
assert_json_contains "${RUN_JSON}" '"disposition":"completed"' 'run smoke'
assert_json_contains "${RUN_JSON}" '"task_completed":true' 'run smoke'
assert_json_contains "${RUN_JSON}" 'llm.origin=deepseek-prod/' 'llm response payload'
printf '%s\n' "${RUN_JSON}" | grep -Eq '"(tool_name|capability_id)":"agent\.dataset"' && {
  printf 'run smoke unexpectedly returned an agent.dataset tool payload instead of LLM response\n' >&2
  exit 1
}

test -f /usr/share/dasall/sql/memory/V001__initial_schema.sql
test -f /usr/share/dasall/sql/memory/V002__vector_sidecar.sql
test -f "${VECTOR0_PATH}"
test -f "${VSS0_PATH}"
test -f "${MEMORY_DB_PATH}"
JOURNAL_MODE=$(query_sqlite_scalar "${MEMORY_DB_PATH}" 'PRAGMA journal_mode;')
[ "${JOURNAL_MODE}" = "wal" ] || {
  printf 'memory sqlite journal mode should be wal, got %s\n' "${JOURNAL_MODE}" >&2
  exit 1
}
CORE_TABLE_COUNT=$(query_sqlite_scalar "${MEMORY_DB_PATH}" "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name IN ('sessions','turns','summaries','facts','experiences');")
[ "${CORE_TABLE_COUNT}" -eq 5 ] || {
  printf 'memory sqlite schema should expose five core tables, got %s\n' "${CORE_TABLE_COUNT}" >&2
  exit 1
}
VECTOR_DOC_TABLE_COUNT=$(query_sqlite_scalar "${MEMORY_DB_PATH}" "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name = 'memory_vector_documents';")
[ "${VECTOR_DOC_TABLE_COUNT}" -eq 1 ] || {
  printf 'memory sqlite schema should expose the vector sidecar table, got %s\n' "${VECTOR_DOC_TABLE_COUNT}" >&2
  exit 1
}
VECTOR_INDEX_TABLE_COUNT=$(query_sqlite_scalar "${MEMORY_DB_PATH}" "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name = 'memory_vector_index';")
[ "${VECTOR_INDEX_TABLE_COUNT}" -eq 1 ] || {
  printf 'memory sqlite schema should expose the sqlite-vss virtual table, got %s\n' "${VECTOR_INDEX_TABLE_COUNT}" >&2
  exit 1
}
VECTOR_DOC_ROW_COUNT=$(query_sqlite_scalar "${MEMORY_DB_PATH}" 'SELECT COUNT(*) FROM memory_vector_documents;')
assert_positive_integer "${VECTOR_DOC_ROW_COUNT}" 'memory vector sidecar rows'
VECTOR_INDEX_ROW_COUNT=$(query_sqlite_scalar "${MEMORY_DB_PATH}" 'SELECT COUNT(*) FROM memory_vector_index;')
assert_positive_integer "${VECTOR_INDEX_ROW_COUNT}" 'memory sqlite-vss index rows'

systemctl stop dasall-daemon.service
mkdir -p "${VECTOR_ASSET_BACKUP_DIR}"
mv "${VECTOR0_PATH}" "${VECTOR_ASSET_BACKUP_DIR}/vector0.so"
mv "${VSS0_PATH}" "${VECTOR_ASSET_BACKUP_DIR}/vss0.so"
set +e
VALIDATE_STDERR=$(/usr/sbin/dasall-daemon \
  --validate-only \
  --profile-id="${DASALL_DAEMON_PROFILE_ID}" \
  --config-file /etc/dasall/daemon.json 2>&1)
VALIDATE_CODE=$?
set -e
mv "${VECTOR_ASSET_BACKUP_DIR}/vector0.so" "${VECTOR0_PATH}"
mv "${VECTOR_ASSET_BACKUP_DIR}/vss0.so" "${VSS0_PATH}"
rmdir "${VECTOR_ASSET_BACKUP_DIR}"
[ "${VALIDATE_CODE}" -ne 0 ] || {
  printf 'validate-only should fail closed when sqlite-vss assets are missing\n' >&2
  exit 1
}
printf '%s\n' "${VALIDATE_STDERR}" | grep -Eq 'sqlite-vss-assets-missing|memory-vector-fail-closed' || {
  printf 'validate-only should surface sqlite-vss fail-closed detail, got: %s\n' "${VALIDATE_STDERR}" >&2
  exit 1
}
systemctl start dasall-daemon.service
wait_for_daemon_ready

set +e
STATUS_JSON=$(dasall status receipt:missing token local://uid/0 --json 2>&1)
STATUS_CODE=$?
set -e
[ "${STATUS_CODE}" -eq 5 ] || {
  printf 'status missing receipt should exit 5, got %s: %s\n' "${STATUS_CODE}" "${STATUS_JSON}" >&2
  exit 1
}
assert_json_contains "${STATUS_JSON}" '"error_ref":"status_missing"' 'status missing receipt'

set +e
CANCEL_JSON=$(dasall cancel receipt:missing token local://uid/0 --json 2>&1)
CANCEL_CODE=$?
set -e
[ "${CANCEL_CODE}" -eq 5 ] || {
  printf 'cancel missing receipt should exit 5, got %s: %s\n' "${CANCEL_CODE}" "${CANCEL_JSON}" >&2
  exit 1
}
assert_json_contains "${CANCEL_JSON}" '"error_ref":"cancel_missing"' 'cancel missing receipt'

DIAG_JSON=$(dasall diag health --json)
assert_json_contains "${DIAG_JSON}" '"disposition":"completed"' 'diag health'
assert_json_contains "${DIAG_JSON}" 'diagnostics redacted health snapshot' 'diag health'

test -f /usr/share/dasall/llm/prompts/planner/default/manifest.yaml
test -f /usr/share/dasall/llm/providers/catalog.yaml
test -f /usr/share/dasall/llm/providers/deepseek/manifest.yaml
test -f /usr/share/dasall/docs/architecture/DASALL_Engineering_Blueprint.md
test -f /usr/share/dasall/docs/adr/ADR-006-context-orchestrator-vs-prompt-composer.md
test -f /usr/share/dasall/docs/ssot/BusinessChainIntegrationMatrix.md
dasall version >/dev/null