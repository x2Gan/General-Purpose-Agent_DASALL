#!/usr/bin/make -f

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export DH_DATAFILES ?= $(abspath $(dir $(shell command -v dh))/../share/debhelper)

BUILD_DIR := obj-$(DEB_HOST_GNU_TYPE)
SQLITE_AUTOCONF_VERSION := 3510300
SQLITE_CACHE_DIR_VERSIONED := $(CURDIR)/third_party/.cache/dasall_sqlite_autoconf-$(SQLITE_AUTOCONF_VERSION)-src
SQLITE_CACHE_DIR_LEGACY := $(CURDIR)/third_party/.cache/dasall_sqlite_autoconf-src
CPP_TIKTOKEN_COMMIT := 9323db528d52e48900c75ce197c3251085b18480
CPP_TIKTOKEN_CACHE_DIR_VERSIONED := $(CURDIR)/third_party/.cache/dasall_cpp_tiktoken-$(CPP_TIKTOKEN_COMMIT)-src
CPP_TIKTOKEN_CACHE_DIR_LEGACY := $(CURDIR)/third_party/.cache/dasall_cpp_tiktoken-src

ifneq ($(wildcard $(SQLITE_CACHE_DIR_VERSIONED)/sqlite3.c),)
SQLITE_CACHE_DIR := $(SQLITE_CACHE_DIR_VERSIONED)
else ifneq ($(wildcard $(SQLITE_CACHE_DIR_LEGACY)/sqlite3.c),)
SQLITE_CACHE_DIR := $(SQLITE_CACHE_DIR_LEGACY)
else
SQLITE_CACHE_DIR :=
endif

ifneq ($(wildcard $(CPP_TIKTOKEN_CACHE_DIR_VERSIONED)/cl100k_base.tiktoken),)
CPP_TIKTOKEN_CACHE_DIR := $(CPP_TIKTOKEN_CACHE_DIR_VERSIONED)
else ifneq ($(wildcard $(CPP_TIKTOKEN_CACHE_DIR_LEGACY)/cl100k_base.tiktoken),)
CPP_TIKTOKEN_CACHE_DIR := $(CPP_TIKTOKEN_CACHE_DIR_LEGACY)
else
CPP_TIKTOKEN_CACHE_DIR :=
endif

ifneq ($(SQLITE_CACHE_DIR),)
SQLITE_SOURCE_FLAG := -DFETCHCONTENT_SOURCE_DIR_DASALL_SQLITE_AUTOCONF=$(SQLITE_CACHE_DIR)
else
SQLITE_SOURCE_FLAG := -DDASALL_BOOTSTRAP_THIRD_PARTY=ON -DFETCHCONTENT_FULLY_DISCONNECTED=OFF
endif

ifneq ($(CPP_TIKTOKEN_CACHE_DIR),)
CPP_TIKTOKEN_SOURCE_FLAG := -DFETCHCONTENT_SOURCE_DIR_DASALL_CPP_TIKTOKEN_SOURCE=$(CPP_TIKTOKEN_CACHE_DIR)
else
CPP_TIKTOKEN_SOURCE_FLAG := -DDASALL_BOOTSTRAP_THIRD_PARTY=ON -DFETCHCONTENT_FULLY_DISCONNECTED=OFF
endif

%:
	dh $@ --buildsystem=cmake --builddirectory=$(BUILD_DIR)

override_dh_auto_configure:
	dh_auto_configure --builddirectory=$(BUILD_DIR) -- \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DDASALL_ENABLE_TESTS=OFF \
		$(SQLITE_SOURCE_FLAG) \
		$(CPP_TIKTOKEN_SOURCE_FLAG)

override_dh_installsystemd:
	dh_installsystemd --no-start --no-enable

override_dh_auto_test:
	@echo "Skipping dh_auto_test; package preflight runs outside dpkg-buildpackage"